# ── GoldTrade Gatekeeper — Backend Config ────────────────────────────────────
# Copy to .env and edit as needed

# SQLite (default) — change to postgres://user:pass@host/db for Postgres
DATABASE_URL=sqlite:///./goldtrade.db

# Risk rules
MAX_TRADES_PER_DAY=3
MAX_DAILY_LOSS_PCT=2.0
RISK_PER_TRADE_PCT=1.0

# Volatility
ATR_EXPANSION_MULTIPLIER=1.5
ATR_AVG_PERIODS=20

# News window (minutes either side of event)
NEWS_WINDOW_MINUTES=30

# CORS — restrict in production
CORS_ORIGINS=*
